DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=sqlite:///db.sqlite3

# Email — console backend when DEBUG=True; set EMAIL_BACKEND to test SendGrid locally
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
SENDGRID_API_KEY=
EMAIL_FAIL_SILENTLY=False
DEFAULT_FROM_EMAIL=WC 2026 Predictions <noreply@example.com>
SERVER_EMAIL=
ACCOUNT_EMAIL_VERIFICATION=optional
ACCOUNT_EMAIL_SUBJECT_PREFIX=[WC 2026]

# One-time production admin (used by bootstrap_admin on Railway pre-deploy)
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=

# OAuth — Google sign-in (optional; button hidden until both are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URIs to register in Google Cloud Console:
#   http://127.0.0.1:8000/accounts/google/login/callback/
#   https://your-domain/accounts/google/login/callback/
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# Celery / Redis (optional — only if you run Celery worker; cron does not need Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Site info (About / Contact / Privacy pages)
SITE_NAME=FIFA WC 2026 Prediction Game
SITE_CONTACT_EMAIL=contact@myprediction.today
LEGAL_LAST_UPDATED=11 June 2026

# Google AdSense (optional — see docs/GOOGLE-ADSENSE.md; keep False locally)
# GOOGLE_ADSENSE_CLIENT also powers https://your-domain/ads.txt (required by AdSense)
GOOGLE_ADSENSE_ENABLED=False
GOOGLE_ADSENSE_CLIENT=
GOOGLE_ADSENSE_SLOT_FOOTER=
GOOGLE_ADSENSE_SLOT_SIDEBAR=

# AI Predict (Gemini) — GOOGLE_API_KEY only; other settings in Django admin → Game Settings
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=
